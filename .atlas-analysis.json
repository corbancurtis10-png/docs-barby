{
  "projectType": "sdk-library",
  "projectName": "EZAnimation",
  "projectDescription": "A Roblox Luau animation library that makes it easy to play, stop, queue, crossfade, tween, lerp, and ragdoll character animations on any model.",
  "theme": "luma",
  "primaryColor": "#ef7025",
  "lightColor": "#eec9bc",
  "darkColor": "#4fa1ab",
